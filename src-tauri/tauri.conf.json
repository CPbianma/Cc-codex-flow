{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Flow",
  "version": "0.1.0",
  "identifier": "com.duogent.flow",
  "build": {
    "beforeDevCommand": "node ./node_modules/vite/bin/vite.js",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node ./node_modules/vite/bin/vite.js build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Flow — Claude × Codex",
        "width": 1400,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
