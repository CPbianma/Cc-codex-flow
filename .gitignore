# Logs
logs
*.log
!docs/evidence/*.log

# Playwright MCP scratch dir
.playwright-mcp/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
